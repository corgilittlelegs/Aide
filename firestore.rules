rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trackers/{syncCode} {
      // Fetching a tracker requires knowing its exact sync code.
      allow get: if true;
      // Never allow enumerating the collection.
      allow list: if false;
      // Writes must match the tracker schema; no extra fields.
      allow create, update: if
        request.resource.data.keys().hasOnly(
          ['attendance', 'baseSalary', 'freeAbsentsPerMonth',
           'cashAdvances', 'settlements', 'updatedAt'])
        && request.resource.data.baseSalary is number
        && request.resource.data.freeAbsentsPerMonth is number
        && (!('cashAdvances' in request.resource.data)
            || request.resource.data.cashAdvances is list)
        && (!('attendance' in request.resource.data)
            || request.resource.data.attendance is map)
        && (!('settlements' in request.resource.data)
            || request.resource.data.settlements is map);
      allow delete: if false;
    }
  }
}
